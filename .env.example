TELEGRAM_BOT_TOKEN=coloque_o_token_do_bot_aqui
TELEGRAM_CHAT_ID=-1001234567890
POST_INTERVAL_MINUTES=180
CAMPAIGNS_FILE=./config/campaigns.json
RUN_ON_START=true
TIMEZONE=America/Sao_Paulo
ADMIN_HOST=127.0.0.1
ADMIN_PORT=8787
ADMIN_PATH=/console
ADMIN_USERNAME_HASH=hash_sha256_do_usuario
ADMIN_PASSWORD_HASH=scrypt:sal_hex:hash_hex
ADMIN_SESSION_SECRET=troque-por-uma-chave-bem-longa

# Amazon PA-API 5.0 funciona no momento, mas a própria Amazon informa
# descontinuação em 30/04/2026 e migração para a Creators API.
AMAZON_PARTNER_TAG=seu_partner_tag-20
AMAZON_ACCESS_KEY=coloque_access_key_aqui
AMAZON_SECRET_KEY=coloque_secret_key_aqui
AMAZON_REGION=us-east-1
AMAZON_HOST=webservices.amazon.com
AMAZON_MARKETPLACE=www.amazon.com.br

# Mercado Livre: a busca de itens é oficial, mas a geração automática
# de link de afiliado não aparece em documentação pública. Por isso,
# o projeto aceita usar o link direto do produto ou um template próprio.
MERCADOLIVRE_SITE_ID=MLB
MERCADOLIVRE_AGENT_USERNAME=colaborador_afiliado@exemplo.com
MERCADOLIVRE_AGENT_PASSWORD=senha_do_colaborador
MERCADOLIVRE_AFFILIATE_LINKBUILDER_URL=https://www.mercadolivre.com.br/afiliados/linkbuilder#hub
MERCADOLIVRE_OFFERS_URL=https://www.mercadolivre.com.br/ofertas#nav-header
